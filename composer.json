{
    "name": "vanilla-groupe/madagascar",
    "description": "Vanilla Groupe Madagascar – Custom PHP 8.4 MVC Website",
    "type": "project",
    "require": {
        "php": ">=8.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Core\\": "core/"
        },
        "files": [
