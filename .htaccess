Options -Indexes
DirectoryIndex index.php

# ═══════════════════════════════════════════════════════════════
# ROOT .htaccess — LiteSpeed + Namecheap shared hosting
#
# Document root = PROJECT ROOT (not /public/)
# Entry point   = index.php (project root) → Application::run()
# Assets path   = /public/assets/* served directly
# ═══════════════════════════════════════════════════════════════

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # ── 1. Allow real files & directories (assets, images, etc.) ──
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # ── 2. Language-aware root redirect (only on bare /) ──────────
    RewriteCond %{REQUEST_URI} ^/?$
    RewriteCond %{HTTP:Accept-Language} ^es [NC]
    RewriteRule ^ /es/ [R=302,L]

    RewriteCond %{REQUEST_URI} ^/?$
    RewriteCond %{HTTP:Accept-Language} ^en [NC]
    RewriteRule ^ /en/ [R=302,L]

    RewriteCond %{REQUEST_URI} ^/?$
    RewriteRule ^ /fr/ [R=302,L]

    # ── 3. All other requests → root index.php (single rewrite) ───
    RewriteRule ^ index.php [QSA,L]
</IfModule>

# Fallback if mod_rewrite is disabled
<IfModule !mod_rewrite.c>
    DirectoryIndex index.php
</IfModule>

# ── Block sensitive files ─────────────────────────────────────────
<FilesMatch "\.(env|sql|sh|md|lock|log|gitignore|gitattributes)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Deny from all
    </IfModule>
</FilesMatch>

# ── Block dot-files (except .well-known for SSL verification) ─────
<FilesMatch "^\.(?!well-known)">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Deny from all
    </IfModule>
</FilesMatch>
