APP_NAME="Vanilla Groupe Madagascar"
APP_URL=https://www.vanillagroup-madagascar.tsilizy.com
APP_ENV=production
APP_DEBUG=false

# ── Database ─────────────────────────────────────────────────
# cPanel: use the DB name exactly as shown in MySQL Databases
DB_HOST=localhost
DB_PORT=3306
DB_NAME=tsilscpx_vanilla_db
DB_USER=tsilscpx_chibi_admin
DB_PASS=9@UPN~I@O]Dw
DB_CHARSET=utf8mb4

# ── Session ──────────────────────────────────────────────────
SESSION_LIFETIME=120

# ── Mail ─────────────────────────────────────────────────────
# Option 1: PHP mail() via cPanel — use MAIL_DRIVER=mail
# Option 2: SMTP via cPanel Pro Mail or any SMTP provider
MAIL_DRIVER=smtp
MAIL_HOST=mail.vanillagroupe.mg
MAIL_PORT=465
MAIL_USERNAME=contact@vanillagroupe.mg
MAIL_PASSWORD=your_email_password
MAIL_ENCRYPTION=ssl
MAIL_FROM=contact@vanillagroupe.mg
MAIL_FROM_NAME="Vanilla Groupe Madagascar"

# ── Stripe (optional — for online payment) ───────────────────
STRIPE_PUBLIC_KEY=pk_live_xxx
STRIPE_SECRET_KEY=sk_live_xxx

# ── Admin ────────────────────────────────────────────────────
